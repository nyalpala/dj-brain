# ==========================================
# DJ Brain - .gitignore
# ==========================================

# --------------------------
# Python
# --------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual Environments
backend/.venv/
venv/
.env
.env.*

# --------------------------
# Logs
# --------------------------
logs/
*.log

# --------------------------
# Coverage
# --------------------------
.coverage
htmlcov/
.coverage.*

# --------------------------
# Build Artifacts
# --------------------------
build/
dist/
*.egg-info/

# --------------------------
# Node / React
# --------------------------
frontend/node_modules/
frontend/dist/
frontend/.vite/

# --------------------------
# IDE
# --------------------------
.vscode/*
!.vscode/extensions.json

.idea/

# --------------------------
# macOS
# --------------------------
.DS_Store

# --------------------------
# GitHub Codespaces
# --------------------------
.devcontainer/.env

# --------------------------
# Database
# --------------------------
*.sqlite3

# --------------------------
# Environment Files
# --------------------------
backend/.env
frontend/.env